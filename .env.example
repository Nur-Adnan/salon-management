# Copy to .env and fill in. NEVER commit .env (see .gitignore + CI secret scan).

# ---------- API (apps/api, NestJS) ----------
NODE_ENV=development
API_PORT=4000

# Mongo must be a replica set (transactions + change streams). docker-compose
# provides a single-node rs0. directConnection avoids host/replset DNS issues.
MONGODB_URI=mongodb://localhost:27017/salon?replicaSet=rs0&directConnection=true

REDIS_URL=redis://localhost:6379

# CORS allowlist for the two web apps.
WEB_ORIGINS=http://localhost:3000,http://localhost:3001

# Supabase = identity provider ONLY (Phase 1 wires JWT validation). Empty in Phase 0.
SUPABASE_URL=
SUPABASE_JWKS_URL=
SUPABASE_JWT_SECRET=

# ---------- Web apps (apps/admin, apps/booking) ----------
NEXT_PUBLIC_API_URL=http://localhost:4000
